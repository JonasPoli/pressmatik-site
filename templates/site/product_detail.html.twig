{# templates/site/product_detail.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Pressmatik - {{ 'product_detail.title'|trans }}{% endblock %}

{% block body %}
    {% set subproducts = [
        {
            'model': 'PMC-ST',
            'name': 'product_detail.subproducts.st.name'|trans,
            'desc': 'product_detail.subproducts.st.desc'|trans,
            'tag': 'Standard',
            'img': '/images/pmc-st.png'
        },
        {
            'model': 'PMC-BC',
            'name': 'product_detail.subproducts.bc.name'|trans,
            'desc': 'product_detail.subproducts.bc.desc'|trans,
            'tag': 'Compact',
            'img': '/images/pmc-bc.png'
        },
        {
            'model': 'PMC-GT',
            'name': 'product_detail.subproducts.gt.name'|trans,
            'desc': 'product_detail.subproducts.gt.desc'|trans,
            'tag': 'High Output',
            'img': '/images/pmc-gt.png'
        },
        {
            'model': 'PMC-TR',
            'name': 'product_detail.subproducts.tr.name'|trans,
            'desc': 'product_detail.subproducts.tr.desc'|trans,
            'tag': 'Deflashing',
            'img': '/images/pmc-hz.png'
        },
        {
            'model': 'PMC-MT',
            'name': 'product_detail.subproducts.mt.name'|trans,
            'desc': 'product_detail.subproducts.mt.desc'|trans,
            'tag': 'Heavy Die',
            'img': '/images/pmc-mt.png'
        },
        {
            'model': 'PMC-AL',
            'name': 'product_detail.subproducts.al.name'|trans,
            'desc': 'product_detail.subproducts.al.desc'|trans,
            'tag': 'Precision',
            'img': '/images/pmc-st.png'
        },
        {
            'model': 'PMC-HZ',
            'name': 'product_detail.subproducts.hz.name'|trans,
            'desc': 'product_detail.subproducts.hz.desc'|trans,
            'tag': 'Assembly',
            'img': '/images/pmc-hz.png'
        },
        {
            'model': 'PMC-ES',
            'name': 'product_detail.subproducts.es.name'|trans,
            'desc': 'product_detail.subproducts.es.desc'|trans,
            'tag': 'Custom',
            'img': '/images/pmc-es.png'
        }
    ] %}

    <div class="container product-detail-layout">
        <!-- Breadcrumbs -->
        <div class="breadcrumbs scroll-animate">
            <a href="{{ path('app_home', {'_locale': locale}) }}">{{ 'menu.home'|trans }}</a>
            <span>/</span>
            <a href="{{ path('app_home', {'_locale': locale}) ~ '#products' }}">{{ 'menu.products'|trans }}</a>
            <span>/</span>
            <span style="color: var(--color-accent-red);">{{ 'product_detail.title'|trans }}</span>
        </div>

        <!-- Product Introduction (Above the Fold) -->
        <div class="product-intro-grid">
            <div class="product-gallery scroll-animate">
                <img src="/images/pmc-st.png" alt="C-Frame Single Crank Deep Throat Press" loading="lazy">
            </div>
            
            <div class="product-meta-panel scroll-animate">
                <span class="product-tag">{{ 'product_detail.tag'|trans }}</span>
                <h1>{{ 'product_detail.title'|trans }}</h1>
                <div class="product-tonnage">
                    {{ 'product_detail.spec_capacity'|trans }}: 25 ~ 160 {{ 'product_detail.tons'|trans }}
                </div>
                <p class="product-description">
                    {{ 'product_detail.short_desc'|trans }}
                </p>
                <div class="product-action-buttons">
                    <wa-button variant="brand" size="large" href="#quote-product-form">
                        {{ 'product_detail.quote_product'|trans }}
                    </wa-button>
                    <!-- Simulated PDF catalog download using a javascript trigger for premium feel -->
                    <wa-button variant="neutral" size="large" outline onclick="alert('Iniciando download do Catálogo Técnico PMC-ST.pdf...');">
                        <i class="bi bi-download" style="margin-right: 8px;"></i>
                        {{ 'cta.download_catalog'|trans }}
                    </wa-button>
                </div>
            </div>
        </div>

        <!-- Product Overview & Detailed Features -->
        <section class="product-overview-section scroll-animate" style="margin-top: 6rem; margin-bottom: 6rem;">
            <div class="overview-header" style="margin-bottom: 3.5rem; text-align: left; max-width: 900px;">
                <span class="section-title-tag">{{ 'product_detail.overview_heading'|trans }}</span>
                <h2 style="font-size: 2.5rem; margin-top: 1rem; margin-bottom: 1.5rem; font-weight: 800; font-family: var(--font-heading);">{{ 'product_detail.overview_heading'|trans }}</h2>
                <p style="color: var(--color-text-secondary); font-size: 1.15rem; line-height: 1.8; margin: 0;">
                    {{ 'product_detail.overview_text'|trans }}
                </p>
            </div>

            <div class="overview-details-grid">
                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_1_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_1_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-gear-wide-connected"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_2_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_2_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-check-all"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_3_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_3_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-cpu"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_4_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_4_desc'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tabs Component (Especificações, Características, Opcionais, Vídeos) -->
        <div class="product-tabs-section scroll-animate">
            <wa-tab-group>
                <wa-tab slot="nav" panel="specs">{{ 'product_detail.specs_title'|trans }}</wa-tab>
                <wa-tab slot="nav" panel="features">{{ 'product_detail.features_title'|trans }}</wa-tab>
                <wa-tab slot="nav" panel="config">{{ 'product_detail.config_title'|trans }}</wa-tab>
                <wa-tab slot="nav" panel="videos">{{ 'product_detail.videos_title'|trans }}</wa-tab>

                <!-- Technical Specification Table Panel (Full Qiaosen Deep Throat Grid) -->
                <wa-tab-panel name="specs">
                    <div class="specs-table-wrapper">
                        <table class="specs-table">
                            <thead>
                                <tr>
                                    <th rowspan="2" style="vertical-align: middle;">{{ 'product_detail.spec_name'|trans }}</th>
                                    <th rowspan="2" style="vertical-align: middle;">{{ 'product_detail.spec_unit'|trans }}</th>
                                    <th colspan="2" style="text-align: center;">PMC-25</th>
                                    <th colspan="2" style="text-align: center;">PMC-35</th>
                                    <th colspan="2" style="text-align: center;">PMC-45</th>
                                    <th colspan="2" style="text-align: center;">PMC-60</th>
                                    <th colspan="2" style="text-align: center;">PMC-80</th>
                                    <th colspan="2" style="text-align: center;">PMC-110</th>
                                    <th colspan="2" style="text-align: center;">PMC-160</th>
                                </tr>
                                <tr>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">V-type</th>
                                    <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">H-type</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>{{ 'product_detail.spec_mode'|trans }}</td>
                                    <td>-</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                    <td>V-type</td><td>H-type</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_capacity'|trans }}</td>
                                    <td>Ton</td>
                                    <td colspan="2">25</td>
                                    <td colspan="2">35</td>
                                    <td colspan="2">45</td>
                                    <td colspan="2">60</td>
                                    <td colspan="2">80</td>
                                    <td colspan="2">110</td>
                                    <td colspan="2">160</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_rated_tonnage_point'|trans }}</td>
                                    <td>mm</td>
                                    <td>3.2</td><td>1.6</td>
                                    <td>3.2</td><td>1.6</td>
                                    <td>3.2</td><td>1.6</td>
                                    <td>4.0</td><td>2.0</td>
                                    <td>4.0</td><td>2.0</td>
                                    <td>6.0</td><td>3.0</td>
                                    <td>6.0</td><td>3.0</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_speed'|trans }}</td>
                                    <td>S.P.M</td>
                                    <td>60~140</td><td>130~200</td>
                                    <td>40~120</td><td>110~180</td>
                                    <td>40~100</td><td>110~150</td>
                                    <td>35~90</td><td>80~120</td>
                                    <td>35~80</td><td>80~120</td>
                                    <td>30~60</td><td>60~90</td>
                                    <td>20~50</td><td>40~70</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_stroke'|trans }}</td>
                                    <td>mm</td>
                                    <td>60</td><td>30</td>
                                    <td>70</td><td>40</td>
                                    <td>80</td><td>50</td>
                                    <td>120</td><td>60</td>
                                    <td>150</td><td>70</td>
                                    <td>180</td><td>80</td>
                                    <td>200</td><td>90</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_die_height'|trans }}</td>
                                    <td>mm</td>
                                    <td>200</td><td>215</td>
                                    <td>220</td><td>235</td>
                                    <td>250</td><td>265</td>
                                    <td>310</td><td>340</td>
                                    <td>340</td><td>380</td>
                                    <td>360</td><td>410</td>
                                    <td>460</td><td>510</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_slide_adjustment'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">50</td>
                                    <td colspan="2">55</td>
                                    <td colspan="2">60</td>
                                    <td colspan="2">75</td>
                                    <td colspan="2">80</td>
                                    <td colspan="2">80</td>
                                    <td colspan="2">100</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_slide_size'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">470*230*50</td>
                                    <td colspan="2">520*250*50</td>
                                    <td colspan="2">560*340*60</td>
                                    <td colspan="2">700*400*70</td>
                                    <td colspan="2">770*420*70</td>
                                    <td colspan="2">910*470*80</td>
                                    <td colspan="2">990*550*90</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.bolster_size'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">680*300*70</td>
                                    <td colspan="2">800*400*70</td>
                                    <td colspan="2">850*440*80</td>
                                    <td colspan="2">900*500*80</td>
                                    <td colspan="2">1000*550*90</td>
                                    <td colspan="2">1150*600*110</td>
                                    <td colspan="2">1250*800*140</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.throat_depth'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">155~1250</td>
                                    <td colspan="2">205~1250</td>
                                    <td colspan="2">225~1250</td>
                                    <td colspan="2">255~1250</td>
                                    <td colspan="2">280~1250</td>
                                    <td colspan="2">305~1250</td>
                                    <td colspan="2">405~1250</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_platform_floor'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">795</td>
                                    <td colspan="2">790</td>
                                    <td colspan="2">790</td>
                                    <td colspan="2">785</td>
                                    <td colspan="2">830</td>
                                    <td colspan="2">830</td>
                                    <td colspan="2">900</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_shank_hole'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">Φ38.1</td>
                                    <td colspan="2">Φ38.1</td>
                                    <td colspan="2">Φ38.1</td>
                                    <td colspan="2">Φ50</td>
                                    <td colspan="2">Φ50</td>
                                    <td colspan="2">Φ50</td>
                                    <td colspan="2">Φ65</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_motor'|trans }}</td>
                                    <td>kW*P</td>
                                    <td colspan="2">3.7*4</td>
                                    <td colspan="2">3.7*4</td>
                                    <td colspan="2">5.5*4</td>
                                    <td colspan="2">5.5*4</td>
                                    <td colspan="2">7.5*4</td>
                                    <td colspan="2">11*4</td>
                                    <td colspan="2">15*4</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_adjust_device'|trans }}</td>
                                    <td>/</td>
                                    <td colspan="8">Manual</td>
                                    <td colspan="6">Electric / Motorizado</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_air_pressure'|trans }}</td>
                                    <td>kg/cm²</td>
                                    <td colspan="14">6</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_accuracy_grade'|trans }}</td>
                                    <td>Grade</td>
                                    <td colspan="14">JIS 1</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_dimension'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">1280*850*2200</td>
                                    <td colspan="2">1380*900*2400</td>
                                    <td colspan="2">1575*950*2500</td>
                                    <td colspan="2">1595*1000*2800</td>
                                    <td colspan="2">1800*1180*2980</td>
                                    <td colspan="2">1900*1300*3200</td>
                                    <td colspan="2">2315*1400*3670</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_weight'|trans }}</td>
                                    <td>Tons</td>
                                    <td colspan="2">2.1</td>
                                    <td colspan="2">3.0</td>
                                    <td colspan="2">3.8</td>
                                    <td colspan="2">5.6</td>
                                    <td colspan="2">6.5</td>
                                    <td colspan="2">9.6</td>
                                    <td colspan="2">16.0</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_die_cushion_capacity'|trans }}</td>
                                    <td>Ton</td>
                                    <td colspan="2">/</td>
                                    <td colspan="2">2.3</td>
                                    <td colspan="2">2.3</td>
                                    <td colspan="2">3.6</td>
                                    <td colspan="2">3.6</td>
                                    <td colspan="2">6.3</td>
                                    <td colspan="2">10.0</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_die_cushion_stroke'|trans }}</td>
                                    <td>mm</td>
                                    <td colspan="2">/</td>
                                    <td colspan="2">50</td>
                                    <td colspan="2">50</td>
                                    <td colspan="2">70</td>
                                    <td colspan="2">70</td>
                                    <td colspan="2">80</td>
                                    <td colspan="2">80</td>
                                </tr>
                                <tr>
                                    <td>{{ 'product_detail.spec_die_cushion_area'|trans }}</td>
                                    <td>mm²</td>
                                    <td colspan="2">/</td>
                                    <td colspan="2">300*230</td>
                                    <td colspan="2">300*230</td>
                                    <td colspan="2">350*300</td>
                                    <td colspan="2">450*310</td>
                                    <td colspan="2">500*350</td>
                                    <td colspan="2">650*420</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--color-text-secondary); font-style: italic;">
                        {{ 'product_detail.footnote'|trans }}
                    </p>
                </wa-tab-panel>

                <!-- Features Highlight Panel -->
                <wa-tab-panel name="features">
                    <ul class="features-list">
                        {% for i in 0..7 %}
                            <li>
                                <div class="feature-icon-box">
                                    <i class="bi bi-shield-check-fill" style="color: var(--color-accent-red);"></i>
                                </div>
                                <span>{{ ('product_detail.features_list.' ~ i)|trans }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </wa-tab-panel>

                <!-- Standard / Optional Configurations Panel -->
                <wa-tab-panel name="config">
                    <div class="config-grid">
                        <div class="config-col">
                            <h3>{{ 'product_detail.std_items'|trans }}</h3>
                            <ul class="config-list">
                                {% for i in 0..22 %}
                                    <li><i class="bi bi-check-circle-fill" style="color: var(--color-accent-red); margin-right: 8px;"></i>{{ ('product_detail.std.' ~ i)|trans }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                        
                        <div class="config-col">
                            <h3>{{ 'product_detail.opt_items'|trans }}</h3>
                            <ul class="config-list">
                                {% for i in 0..11 %}
                                    <li><i class="bi bi-plus-circle-fill" style="color: var(--color-accent-red); margin-right: 8px;"></i>{{ ('product_detail.opt.' ~ i)|trans }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </wa-tab-panel>

                <!-- Videos Showcase Panel -->
                <wa-tab-panel name="videos">
                    <div class="video-container" style="display: flex; justify-content: center; padding: 2rem 0;">
                        <video controls style="width: 100%; max-width: 800px; border-radius: 12px; border: 1px solid var(--color-border); box-shadow: var(--shadow-card-subtle);">
                            <source src="https://www.qiaosenpresses.com/uploads/Deep-Throat-Presses.mp4" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                </wa-tab-panel>
            </wa-tab-group>
        </div>

        <!-- Subproducts Section -->
        <section class="subproducts-section scroll-animate">
            <div class="section-header">
                <span class="section-title-tag">{{ 'product_detail.subproducts_tag'|trans }}</span>
                <h2 class="section-title">{{ 'product_detail.subproducts_title'|trans }}</h2>
                <p class="section-desc">{{ 'product_detail.subproducts_desc'|trans }}</p>
            </div>
            
            <div class="subproducts-grid">
                {% for sub in subproducts %}
                    <div class="subproduct-card">
                        <div class="product-image-container" style="aspect-ratio: 16/11; border-radius: 8px; margin-bottom: 1.5rem;">
                            <img src="{{ sub.img }}" alt="{{ sub.name }}" loading="lazy" style="width: 100%; height: 100%; object-fit: cover;">
                        </div>
                        <span class="subproduct-model">{{ sub.model }}</span>
                        <h4>{{ sub.name }}</h4>
                        <p>{{ sub.desc }}</p>
                        <span class="subproduct-tag-detail">{{ sub.tag }}</span>
                        <wa-button variant="brand" size="small" href="#quote-product-form" style="margin-top: 1.5rem;" onclick="document.getElementById('p-model').value = '{{ sub.model|lower }}';">
                            {{ 'cta.quote_now'|trans }}
                        </wa-button>
                    </div>
                {% endfor %}
            </div>
        </section>

        <!-- Product Quote Form -->
        <section id="quote-product-form" class="section-padding scroll-animate" style="background-color: var(--color-surface-dark); border: 1px solid var(--color-border); border-radius: 16px; padding: 4rem; margin-top: 6rem;">
            <div class="section-header" style="margin-bottom: 3rem;">
                <span class="section-title-tag">{{ 'contact_form.commercial_heading'|trans }}</span>
                <h2>{{ 'contact_form.request_quote_heading'|trans }}</h2>
                <p>{{ 'contact_form.request_quote_desc'|trans }}</p>
            </div>
            
            <form onsubmit="event.preventDefault(); alert('{{ 'contact_form.success'|trans }}'); this.reset();" style="max-width: 600px; margin: 0 auto;">
                <div class="form-group">
                    <wa-input id="p-name" type="text" label="{{ 'contact_form.name'|trans }}" placeholder="Ex: Engenharia Mecânica Ltda" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-input id="p-email" type="email" label="{{ 'contact_form.email'|trans }}" placeholder="comercial@suaempresa.com" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-input id="p-phone" type="tel" label="{{ 'contact_form.phone'|trans }}" placeholder="(16) 99999-9999" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-select id="p-model" label="{{ 'contact_form.selected_model'|trans }}" value="pmc-st">
                        <wa-option value="pmc-st">PMC-ST (Stander)</wa-option>
                        <wa-option value="pmc-bc">PMC-BC (Bancada)</wa-option>
                        <wa-option value="pmc-gt">PMC-GT (Mesa Giratória)</wa-option>
                        <wa-option value="pmc-tr">PMC-TR (Rebarbação)</wa-option>
                        <wa-option value="pmc-mt">PMC-MT (Mesa Móvel)</wa-option>
                        <wa-option value="pmc-al">PMC-AL (Alinhamento)</wa-option>
                        <wa-option value="pmc-hz">PMC-HZ (Horizontal)</wa-option>
                        <wa-option value="pmc-es">PMC-ES (Especial)</wa-option>
                    </wa-select>
                </div>
                <div class="form-group">
                    <wa-textarea id="p-message" label="{{ 'contact_form.message'|trans }}" placeholder="Especificações adicionais (ex: profundidade da garganta customizada, almofada de estampagem, etc.)"></wa-textarea>
                </div>
                
                <wa-button type="submit" variant="brand" style="width: 100%;">
                    {{ 'cta.submit'|trans }}
                </wa-button>
            </form>
        </section>
    </div>
{% endblock %}
