{# templates/site/product_detail.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Pressmatik - {{ product.name_key|trans }}{% endblock %}

{% block body %}
    <div class="container product-detail-layout">
        <!-- Breadcrumbs -->
        <div class="breadcrumbs scroll-animate slide-left">
            <a href="{{ path('app_home', {'_locale': locale}) }}">{{ 'menu.home'|trans }}</a>
            <span>/</span>
            <a href="{{ path('app_home', {'_locale': locale}) ~ '#products' }}">{{ 'menu.products'|trans }}</a>
            <span>/</span>
            <span style="color: var(--color-accent-red);">{{ product.name_key|trans }}</span>
        </div>

        <!-- Product Introduction (Above the Fold) -->
        <div class="product-intro-grid">
            <div class="product-gallery scroll-animate slide-left">
                <wa-carousel navigation pagination loop mouse-dragging autoplay style="width: 100%; height: 100%;">
                    {% for sub in product.subproducts %}
                        <wa-carousel-item>
                            <img src="{{ sub.img }}" alt="{{ sub.name_key|trans }}" style="width: 100%; height: 100%; object-fit: contain; display: block;">
                        </wa-carousel-item>
                    {% endfor %}
                </wa-carousel>
            </div>
            
            <div class="product-meta-panel scroll-animate slide-right">
                <span class="product-tag">{{ 'product_detail.tag'|trans }}</span>
                <h1>{{ product.name_key|trans }}</h1>
                {% if product.tonnage %}
                    <div class="product-tonnage">
                        {{ 'product_detail.spec_capacity'|trans }}: {{ product.tonnage }}
                    </div>
                {% endif %}
                <p class="product-description">
                    {{ product.desc_key|trans }}
                </p>
                <div class="product-action-buttons">
                    <wa-button variant="brand" size="large" href="#quote-product-form">
                        {{ 'product_detail.quote_product'|trans }}
                    </wa-button>
                    <!-- Simulated PDF catalog download using a javascript trigger for premium feel -->
                    <wa-button variant="neutral" size="large" outline onclick="alert('Iniciando download do Catálogo Técnico.pdf...');">
                        <i class="bi bi-download" style="margin-right: 8px;"></i>
                        {{ 'cta.download_catalog'|trans }}
                    </wa-button>
                </div>
            </div>
        </div>

        <!-- Applications Section -->
        {% if product.applications is defined and product.applications is not empty %}
            <section class="product-applications-section scroll-animate slide-top" style="margin-top: 5rem; margin-bottom: 5rem;">
                <div class="overview-header" style="margin-bottom: 3rem; text-align: left;">
                    <span class="section-title-tag">Aplicações</span>
                    <h2 style="font-size: 2.2rem; margin-top: 0.8rem; font-weight: 800; font-family: var(--font-heading);">Aplicações Recomendadas</h2>
                    <p style="color: var(--color-text-secondary); font-size: 1.1rem; line-height: 1.6; margin-top: 0.5rem; max-width: 900px;">
                        Nossas prensas Tipo "C" atendem a uma ampla variedade de processos industriais com alta eficiência e repetibilidade.
                    </p>
                </div>
                
                <div class="applications-grid">
                    {% for app in product.applications %}
                        <div class="application-card">
                            <div class="application-img-wrapper">
                                <img src="{{ app.img }}" alt="{{ app.name_key|trans }}" loading="lazy">
                            </div>
                            <h4>{{ app.name_key|trans }}</h4>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <!-- Product Overview & Detailed Features -->
        <section class="product-overview-section scroll-animate slide-top" style="margin-top: 6rem; margin-bottom: 6rem;">
            <div class="overview-header" style="margin-bottom: 3.5rem; text-align: left; max-width: 900px;">
                <span class="section-title-tag">{{ 'product_detail.overview_heading'|trans }}</span>
                <h2 style="font-size: 2.5rem; margin-top: 1rem; margin-bottom: 1.5rem; font-weight: 800; font-family: var(--font-heading);">{{ 'product_detail.overview_heading'|trans }}</h2>
                <p style="color: var(--color-text-secondary); font-size: 1.15rem; line-height: 1.8; margin: 0;">
                    {{ product.desc_key|trans }}
                </p>
            </div>

            <div class="overview-details-grid">
                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-box-seam"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_1_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_1_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-gear-wide-connected"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_2_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_2_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-check-all"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_3_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_3_desc'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="overview-detail-card">
                    <div class="overview-detail-card-inner">
                        <div class="overview-detail-icon-box">
                            <i class="bi bi-cpu"></i>
                        </div>
                        <div>
                            <h4>{{ 'product_detail.feature_detail_4_title'|trans }}</h4>
                            <p>{{ 'product_detail.feature_detail_4_desc'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Tabs Component (Especificações, Características, Opcionais, Vídeos) -->
        <div class="product-tabs-section scroll-animate slide-top">
            <wa-tab-group>
                {% if product.specs_table is defined and product.specs_table is not null %}
                    <wa-tab slot="nav" panel="specs">{{ 'product_detail.specs_title'|trans }}</wa-tab>
                {% endif %}
                {% if product.features is not empty %}
                    <wa-tab slot="nav" panel="features">{{ 'product_detail.features_title'|trans }}</wa-tab>
                {% endif %}
                {% if product.std_configs is not empty or product.opt_configs is not empty %}
                    <wa-tab slot="nav" panel="config">{{ 'product_detail.config_title'|trans }}</wa-tab>
                {% endif %}
                <wa-tab slot="nav" panel="videos">{{ 'product_detail.videos_title'|trans }}</wa-tab>

                <!-- Technical Specification Table Panel -->
                {% if product.specs_table is defined and product.specs_table is not null %}
                    <wa-tab-panel name="specs">
                        <div class="specs-table-wrapper">
                            <table class="specs-table">
                                <thead>
                                    <tr>
                                        <th rowspan="2" style="vertical-align: middle;">{{ 'product_detail.spec_name'|trans }}</th>
                                        <th rowspan="2" style="vertical-align: middle;">{{ 'product_detail.spec_unit'|trans }}</th>
                                        {% for modelName in product.specs_table.models %}
                                            <th colspan="2" style="text-align: center;">{{ modelName }}</th>
                                        {% endfor %}
                                    </tr>
                                    <tr>
                                        {% for modelName in product.specs_table.models %}
                                            {% for subhead in product.specs_table.headers %}
                                                <th style="text-align: center; border-bottom: 2px solid var(--color-accent-red);">{{ subhead }}</th>
                                            {% endfor %}
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for row in product.specs_table.rows %}
                                        <tr>
                                            <td>{{ row.label_key|trans }}</td>
                                            <td>{{ row.unit }}</td>
                                            {% for val in row.values %}
                                                {% if val is iterable %}
                                                    {% for subval in val %}
                                                        <td style="text-align: center;">{{ subval }}</td>
                                                    {% endfor %}
                                                {% else %}
                                                    <td colspan="2" style="text-align: center;">{{ val }}</td>
                                                {% endif %}
                                            {% endfor %}
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                        <p style="margin-top: 1rem; font-size: 0.85rem; color: var(--color-text-secondary); font-style: italic;">
                            {{ 'product_detail.footnote'|trans }}
                        </p>
                    </wa-tab-panel>
                {% endif %}

                <!-- Features Highlight Panel -->
                {% if product.features is not empty %}
                    <wa-tab-panel name="features">
                        <ul class="features-list">
                            {% for feat in product.features %}
                                <li>
                                    <div class="feature-icon-box">
                                        <i class="bi bi-shield-check-fill" style="color: var(--color-accent-red);"></i>
                                    </div>
                                    <span>{{ feat|trans }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    </wa-tab-panel>
                {% endif %}

                <!-- Standard / Optional Configurations Panel -->
                {% if product.std_configs is not empty or product.opt_configs is not empty %}
                    <wa-tab-panel name="config">
                        <div class="config-grid">
                            {% if product.std_configs is not empty %}
                                <div class="config-col">
                                    <h3>{{ 'product_detail.std_items'|trans }}</h3>
                                    <ul class="config-list">
                                        {% for std in product.std_configs %}
                                            <li><i class="bi bi-check-circle-fill" style="color: var(--color-accent-red); margin-right: 8px;"></i>{{ std|trans }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                            
                            {% if product.opt_configs is not empty %}
                                <div class="config-col">
                                    <h3>{{ 'product_detail.opt_items'|trans }}</h3>
                                    <ul class="config-list">
                                        {% for opt in product.opt_configs %}
                                            <li><i class="bi bi-plus-circle-fill" style="color: var(--color-accent-red); margin-right: 8px;"></i>{{ opt|trans }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        </div>
                    </wa-tab-panel>
                {% endif %}

                <!-- Videos Showcase Panel -->
                <wa-tab-panel name="videos">
                    <div class="video-container" style="display: flex; justify-content: center; padding: 2rem 0;">
                        <video controls style="width: 100%; max-width: 800px; border-radius: 12px; border: 1px solid var(--color-border); box-shadow: var(--shadow-card-subtle);">
                            <source src="https://www.qiaosenpresses.com/uploads/Deep-Throat-Presses.mp4" type="video/mp4">
                            Your browser does not support the video tag.
                        </video>
                    </div>
                </wa-tab-panel>
            </wa-tab-group>
        </div>

        <!-- Modelos Section -->
        <section class="subproducts-section scroll-animate slide-top">
            <div class="section-header">
                <span class="section-title-tag">{{ 'product_detail.models_tag'|trans }}</span>
                <h2 class="section-title">{{ 'product_detail.models_title'|trans }}</h2>
                <p class="section-desc">{{ 'product_detail.models_desc'|trans }}</p>
            </div>
            
            <div class="subproducts-grid">
                {% for sub in product.subproducts %}
                    <div class="subproduct-card">
                        <div class="product-image-container" style="aspect-ratio: 16/11; border-radius: 8px; margin-bottom: 1.5rem; overflow: hidden; border: 1px solid var(--color-border);">
                            <img src="{{ sub.img }}" alt="{{ sub.name_key|trans }}" loading="lazy" style="width: 100%; height: 100%; object-fit: contain; background: var(--color-surface-dark); padding: 0.5rem;">
                        </div>
                        <span class="subproduct-model">{{ sub.model }}</span>
                        <h4>{{ sub.name_key|trans }}</h4>
                        <p>{{ sub.desc_key|trans }}</p>
                        <span class="subproduct-tag-detail">{{ sub.tag }}</span>
                        <wa-button variant="brand" size="small" href="#quote-product-form" style="margin-top: 1.5rem;" onclick="document.getElementById('p-model').value = '{{ sub.model|lower }}';">
                            {{ 'cta.quote_now'|trans }}
                        </wa-button>
                    </div>
                {% endfor %}
            </div>
        </section>

        <!-- Product Quote Form -->
        <section id="quote-product-form" class="section-padding scroll-animate slide-top" style="background-color: var(--color-surface-dark); border: 1px solid var(--color-border); border-radius: 16px; padding: 4rem; margin-top: 6rem;">
            <div class="section-header" style="margin-bottom: 3rem;">
                <span class="section-title-tag">{{ 'contact_form.commercial_heading'|trans }}</span>
                <h2>{{ 'contact_form.request_quote_heading'|trans }}</h2>
                <p>{{ 'contact_form.request_quote_desc'|trans }}</p>
            </div>
            
            <form onsubmit="event.preventDefault(); alert('{{ 'contact_form.success'|trans }}'); this.reset();" style="max-width: 600px; margin: 0 auto;">
                <div class="form-group">
                    <wa-input id="p-name" type="text" label="{{ 'contact_form.name'|trans }}" placeholder="Ex: Engenharia Mecânica Ltda" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-input id="p-email" type="email" label="{{ 'contact_form.email'|trans }}" placeholder="comercial@suaempresa.com" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-input id="p-phone" type="tel" label="{{ 'contact_form.phone'|trans }}" placeholder="(16) 99999-9999" required></wa-input>
                </div>
                <div class="form-group">
                    <wa-select id="p-model" label="{{ 'contact_form.selected_model'|trans }}" value="{{ product.subproducts|first ? (product.subproducts|first).model|lower : '' }}">
                        {% for sub in product.subproducts %}
                            <wa-option value="{{ sub.model|lower }}">{{ sub.model }} ({{ sub.name_key|trans }})</wa-option>
                        {% endfor %}
                    </wa-select>
                </div>
                <div class="form-group">
                    <wa-textarea id="p-message" label="{{ 'contact_form.message'|trans }}" placeholder="Especificações adicionais (ex: profundidade da garganta customizada, almofada de estampagem, etc.)"></wa-textarea>
                </div>
                
                <wa-button type="submit" variant="brand" style="width: 100%;">
                    {{ 'cta.submit'|trans }}
                </wa-button>
            </form>
        </section>
    </div>
{% endblock %}
