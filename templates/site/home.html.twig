{# templates/site/home.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Pressmatik - {{ 'banner.title'|trans }}{% endblock %}

{% block body %}
    <!-- Hero Banner Section (Polished Two-Column Industrial Layout) -->
    <section class="hero-section">
        <div class="container hero-grid">
            <div class="hero-content scroll-animate">
                <span class="section-title-tag">{{ 'banner.tag'|trans }}</span>
                <h1 class="hero-title">{{ 'banner.title'|trans }}</h1>
                <p class="hero-subtitle">{{ 'banner.subtitle'|trans }}</p>
                <div class="hero-buttons">
                    <wa-button variant="brand" size="large" href="#contact">
                        {{ 'cta.quote_now'|trans }}
                    </wa-button>
                    <wa-button variant="neutral" size="large" outline href="#about">
                        {{ 'cta.learn_more'|trans }}
                    </wa-button>
                </div>
            </div>
            
            <div class="hero-visual scroll-animate">
                <div class="hero-image-frame">
                    <img src="/images/pmc-st.png" alt="C-Frame Stamping Press" class="hero-main-img">
                    <div class="hero-badge badge-top">
                        <span class="badge-num">25-315</span>
                        <span class="badge-lbl">Toneladas</span>
                    </div>
                    <div class="hero-badge badge-bottom">
                        <span class="badge-num">JIS Classe 1</span>
                        <span class="badge-lbl">Alta Precisão</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quem Somos (About Us) Section with Image Collage and Bullet Grid -->
    <section id="about" class="section-padding about-section">
        <div class="container about-grid">
            <div class="about-collage scroll-animate">
                <div class="collage-container">
                    <div class="collage-shape"></div>
                    <div class="collage-img-main-frame">
                        <img src="/images/about-press.png" alt="Premium Hydraulic Press Manufacturing" class="collage-img-main">
                    </div>
                    <div class="collage-img-sub-frame">
                        <img src="/images/c-frame-press.png" alt="C-Frame Press Detail" class="collage-img-sub">
                    </div>
                    <div class="collage-badge">
                        <span class="badge-years">15+</span>
                        <span class="badge-text">Anos de Mercado</span>
                    </div>
                </div>
            </div>

            <div class="about-content scroll-animate">
                <span class="section-title-tag">{{ 'about.tag'|trans }}</span>
                <h2>{{ 'about.title'|trans }}</h2>
                <p>{{ 'about.text'|trans }}</p>
                
                <div class="about-bullets">
                    <div class="about-bullet-item">
                        <div class="bullet-icon-wrapper">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div class="bullet-text">
                            <h4>Segurança Avançada (NR12)</h4>
                            <p>Sistemas eletro-hidráulicos monitorados redundantes e cortinas ópticas integradas.</p>
                        </div>
                    </div>
                    <div class="about-bullet-item">
                        <div class="bullet-icon-wrapper">
                            <i class="bi bi-cpu"></i>
                        </div>
                        <div class="bullet-text">
                            <h4>Engenharia e Tecnologia Siemens</h4>
                            <p>CLPs de segurança, painéis de operação IHM Touch e acionamentos robustos de última geração.</p>
                        </div>
                    </div>
                </div>
                
                <wa-button variant="neutral" outline href="#contact" style="margin-top: 1.5rem;">
                    {{ 'menu.contact'|trans }}
                </wa-button>
            </div>
        </div>
    </section>

    <!-- Diferenciais Técnicos Section -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header scroll-animate">
                <span class="section-title-tag">{{ 'differentials.tag'|trans }}</span>
                <h2 class="section-title">{{ 'differentials.title'|trans }}</h2>
            </div>
            
            <div class="diff-grid">
                <!-- Safety card -->
                <div class="diff-card scroll-animate">
                    <div class="diff-card-icon-wrapper">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h3>{{ 'differentials.safety.title'|trans }}</h3>
                    <p>{{ 'differentials.safety.desc'|trans }}</p>
                </div>
                
                <div class="diff-card scroll-animate">
                    <div class="diff-card-icon-wrapper">
                        <i class="bi bi-cpu"></i>
                    </div>
                    <h3>{{ 'differentials.components.title'|trans }}</h3>
                    <p>{{ 'differentials.components.desc'|trans }}</p>
                </div>
                
                <div class="diff-card scroll-animate">
                    <div class="diff-card-icon-wrapper">
                        <i class="bi bi-lightning-charge"></i>
                    </div>
                    <h3>{{ 'differentials.performance.title'|trans }}</h3>
                    <p>{{ 'differentials.performance.desc'|trans }}</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Grade de Destaque de Produtos Section -->
    <section id="products" class="section-padding products-section">
        <div class="container">
            <div class="section-header scroll-animate">
                <span class="section-title-tag">{{ 'products_sec.tag'|trans }}</span>
                <h2 class="section-title">{{ 'products_sec.title'|trans }}</h2>
            </div>

            <div class="products-grid">
                <!-- Product Card: Fictional PMC-ST deep throat press -->
                <div class="product-card scroll-animate">
                    <div class="product-image-container">
                        <img src="/images/pmc-st.png" alt="C-Frame Single Crank Deep Throat Press" loading="lazy">
                    </div>
                    <div class="product-info">
                        <h3>{{ 'product_detail.title'|trans }}</h3>
                        <p>{{ 'product_detail.short_desc'|trans }}</p>
                        <div class="product-footer">
                            <span class="product-specs-badge">25 ~ 160 {{ 'product_detail.tons'|trans }}</span>
                            <wa-button variant="brand" size="small" href="{{ path('app_product_detail', {'_locale': app.request.locale, 'slug': 'c-frame-single-crank-deep-throat-press'}) }}">
                                {{ 'cta.learn_more'|trans }}
                            </wa-button>
                        </div>
                    </div>
                </div>

                <!-- Product Card: Servo Presses -->
                <div class="product-card scroll-animate">
                    <div class="product-image-container">
                        <img src="/images/pmc-es.png" alt="Servo-Hydraulic Press" loading="lazy">
                    </div>
                    <div class="product-info">
                        <h3>{{ 'products_sec.servo_presses'|trans }}</h3>
                        <p>{{ 'products_sec.servo_presses_desc'|trans }}</p>
                        <div class="product-footer">
                            <span class="product-specs-badge">50 ~ 1000 {{ 'product_detail.tons'|trans }}</span>
                            <wa-button variant="brand" size="small" href="#contact">
                                {{ 'cta.quote_now'|trans }}
                            </wa-button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Grade Secundária (Secondary Products) -->
            <div class="secondary-products-grid">
                <div class="secondary-product-card scroll-animate">
                    <div class="sec-prod-icon">
                        <i class="bi bi-gear-wide-connected"></i>
                    </div>
                    <div class="sec-prod-info">
                        <h4>{{ 'products_sec.equipments'|trans }}</h4>
                        <p>{{ 'products_sec.equipments_desc'|trans }}</p>
                    </div>
                </div>

                <div class="secondary-product-card scroll-animate">
                    <div class="sec-prod-icon">
                        <i class="bi bi-database"></i>
                    </div>
                    <div class="sec-prod-info">
                        <h4>{{ 'products_sec.parts'|trans }}</h4>
                        <p>{{ 'products_sec.parts_desc'|trans }}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção de Serviços Section with Video Background -->
    <section id="services" class="section-padding services-video-section">
        <div class="video-bg-container">
            <video autoplay loop muted playsinline class="video-bg">
                <source src="/images/service-bg.mp4" type="video/mp4">
            </video>
            <div class="video-bg-overlay"></div>
        </div>

        <div class="container" style="position: relative; z-index: 2;">
            <div class="section-header scroll-animate">
                <span class="section-title-tag" style="color: var(--color-accent-red);">{{ 'services_sec.tag'|trans }}</span>
                <h2 class="section-title" style="color: #ffffff;">{{ 'services_sec.title'|trans }}</h2>
            </div>

            <div class="services-grid">
                <div class="service-card scroll-animate">
                    <div class="service-img-container">
                        <img src="/images/service-maintenance.png" alt="Manutenção de Prensas" class="service-img" loading="lazy">
                        <div class="service-icon-floating">
                            <i class="bi bi-wrench"></i>
                        </div>
                    </div>
                    <div class="service-card-content">
                        <h3>{{ 'services_sec.maintenance.title'|trans }}</h3>
                        <p>{{ 'services_sec.maintenance.desc'|trans }}</p>
                        <wa-button variant="text" href="#contact" style="padding: 0; display: inline-block; color: #ffffff;">{{ 'cta.quote_now'|trans }} →</wa-button>
                    </div>
                </div>

                <div class="service-card scroll-animate">
                    <div class="service-img-container">
                        <img src="/images/service-retrofit.png" alt="Retrofit de Prensas" class="service-img" loading="lazy">
                        <div class="service-icon-floating">
                            <i class="bi bi-arrow-repeat"></i>
                        </div>
                    </div>
                    <div class="service-card-content">
                        <h3>{{ 'services_sec.refit.title'|trans }}</h3>
                        <p>{{ 'services_sec.refit.desc'|trans }}</p>
                        <wa-button variant="text" href="#contact" style="padding: 0; display: inline-block; color: #ffffff;">{{ 'cta.quote_now'|trans }} →</wa-button>
                    </div>
                </div>

                <div class="service-card scroll-animate">
                    <div class="service-img-container">
                        <img src="/images/service-safety.png" alt="Adequação NR12" class="service-img" loading="lazy">
                        <div class="service-icon-floating">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>
                    <div class="service-card-content">
                        <h3>{{ 'services_sec.nr12.title'|trans }}</h3>
                        <p>{{ 'services_sec.nr12.desc'|trans }}</p>
                        <wa-button variant="text" href="#contact" style="padding: 0; display: inline-block; color: #ffffff;">{{ 'cta.quote_now'|trans }} →</wa-button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Seção de Notícias & Eventos (Blog) -->
    <section id="news" class="section-padding news-section">
        <div class="container">
            <div class="section-header scroll-animate">
                <span class="section-title-tag">{{ 'news.tag'|trans }}</span>
                <h2 class="section-title">{{ 'news.title'|trans }}</h2>
                <p class="section-desc" style="max-width: 700px; color: var(--color-text-secondary); margin-bottom: 3.5rem;">
                    {{ 'news.desc'|trans }}
                </p>
            </div>
            
            <div class="news-grid">
                <!-- Card 1 -->
                <div class="news-card scroll-animate">
                    <div class="news-img-container">
                        <img src="/images/news-exhibition1.png" alt="{{ 'news.items.0.title'|trans }}" class="news-img" loading="lazy">
                        <div class="news-date-badge">
                            {{ 'news.items.0.date'|trans }}
                        </div>
                    </div>
                    <div class="news-card-content">
                        <h3>{{ 'news.items.0.title'|trans }}</h3>
                        <p>{{ 'news.items.0.desc'|trans }}</p>
                        <a href="#contact" class="news-readmore-btn">{{ 'news.read_more'|trans }} <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="news-card scroll-animate">
                    <div class="news-img-container">
                        <img src="/images/news-seminar.png" alt="{{ 'news.items.1.title'|trans }}" class="news-img" loading="lazy">
                        <div class="news-date-badge">
                            {{ 'news.items.1.date'|trans }}
                        </div>
                    </div>
                    <div class="news-card-content">
                        <h3>{{ 'news.items.1.title'|trans }}</h3>
                        <p>{{ 'news.items.1.desc'|trans }}</p>
                        <a href="#contact" class="news-readmore-btn">{{ 'news.read_more'|trans }} <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="news-card scroll-animate">
                    <div class="news-img-container">
                        <img src="/images/news-hannover.png" alt="{{ 'news.items.2.title'|trans }}" class="news-img" loading="lazy">
                        <div class="news-date-badge">
                            {{ 'news.items.2.date'|trans }}
                        </div>
                    </div>
                    <div class="news-card-content">
                        <h3>{{ 'news.items.2.title'|trans }}</h3>
                        <p>{{ 'news.items.2.desc'|trans }}</p>
                        <a href="#contact" class="news-readmore-btn">{{ 'news.read_more'|trans }} <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Depoimentos (Testimonials) Section -->
    <section class="section-padding testimonials-section">
        <div class="container">
            <div class="section-header scroll-animate">
                <span class="section-title-tag">{{ 'testimonials.tag'|trans }}</span>
                <h2 class="section-title">{{ 'testimonials.title'|trans }}</h2>
            </div>

            <div class="testimonials-carousel">
                <div class="testimonial-card scroll-animate">
                    <div class="testimonial-rating">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <p class="testimonial-quote">"{{ 'testimonials.client1.text'|trans }}"</p>
                    <div class="testimonial-client">
                        <img src="/images/client1.jpg" alt="{{ 'testimonials.client1.name'|trans }}" class="client-avatar">
                        <div class="client-meta">
                            <h4>{{ 'testimonials.client1.name'|trans }}</h4>
                            <p>{{ 'testimonials.client1.role'|trans }} - {{ 'testimonials.client1.company'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-card scroll-animate">
                    <div class="testimonial-rating">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <p class="testimonial-quote">"{{ 'testimonials.client2.text'|trans }}"</p>
                    <div class="testimonial-client">
                        <img src="/images/client2.jpg" alt="{{ 'testimonials.client2.name'|trans }}" class="client-avatar">
                        <div class="client-meta">
                            <h4>{{ 'testimonials.client2.name'|trans }}</h4>
                            <p>{{ 'testimonials.client2.role'|trans }} - {{ 'testimonials.client2.company'|trans }}</p>
                        </div>
                    </div>
                </div>

                <div class="testimonial-card scroll-animate">
                    <div class="testimonial-rating">
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                        <i class="bi bi-star-fill"></i>
                    </div>
                    <p class="testimonial-quote">"{{ 'testimonials.client3.text'|trans }}"</p>
                    <div class="testimonial-client">
                        <img src="/images/client3.jpg" alt="{{ 'testimonials.client3.name'|trans }}" class="client-avatar">
                        <div class="client-meta">
                            <h4>{{ 'testimonials.client3.name'|trans }}</h4>
                            <p>{{ 'testimonials.client3.role'|trans }} - {{ 'testimonials.client3.company'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Clientes (Logos) Section -->
    <section class="clients-section">
        <div class="container">
            <div class="clients-grid scroll-animate">
                <span class="client-logo-item" aria-label="Schuler">
